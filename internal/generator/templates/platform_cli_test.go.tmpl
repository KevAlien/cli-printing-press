func TestPlatformCLIConformanceSurfaceAndGate(t *testing.T) {
	configRoot := t.TempDir()
	t.Setenv("XDG_CONFIG_HOME", configRoot)
	t.Setenv("XDG_DATA_HOME", t.TempDir())
	t.Setenv("XDG_CACHE_HOME", t.TempDir())
	t.Setenv("XDG_STATE_HOME", t.TempDir())
	t.Setenv("PRINTING_PRESS_CLIENT_PROFILE", "")

	profile := &platform.Profile{
		SchemaVersion: platform.ProfileSchemaVersion,
		Name:          "tenant-a",
		Sources: map[string]platform.SourceProfile{
			"test-source": {CredentialRef: "op://Test Vault/Test Item/token", ExpectedAccountID: "acct-a"},
		},
	}
	if err := platform.SaveProfile(profile); err != nil {
		t.Fatal(err)
	}

	previousRegistration := registeredPlatformSource
	previousResolver := platformResolverFactory
	t.Cleanup(func() {
		registeredPlatformSource = previousRegistration
		platformResolverFactory = previousResolver
	})
	registeredPlatformSource = &platformSourceRegistration{
		Source:  "test-source",
		Adapter: conformanceIdentityAdapter{observed: platform.ObservedIdentity{AccountID: "acct-a"}},
	}
	platformResolverFactory = func() platform.CredentialResolver {
		return conformanceResolver{value: []byte("credential-bytes-never-print")}
	}

	root := RootCmd()
	for _, path := range []string{
		"client add", "client source set", "client list", "client show", "client validate",
		"client set-default", "client migrate", "client delete", "client cache clear", "whoami",
	} {
		parts := strings.Fields(path)
		command, _, err := root.Find(parts)
		if err != nil || command == nil || command.Name() != parts[len(parts)-1] {
			t.Fatalf("missing platform command %q: command=%v err=%v", path, command, err)
		}
	}
	if root.PersistentFlags().Lookup("client-profile") == nil || root.PersistentFlags().Lookup("receipt") == nil || root.PersistentFlags().Lookup("audit-dir") == nil {
		t.Fatal("platform root flags are missing")
	}

	var output bytes.Buffer
	root.SetOut(&output)
	root.SetErr(&output)
	root.SetArgs([]string{"whoami", "--client-profile", "tenant-a", "--json"})
	if err := root.Execute(); err != nil {
		t.Fatal(err)
	}
	got := output.String()
	if !strings.Contains(got, `"gate": "verified"`) || !strings.Contains(got, `"account_id": "acct-a"`) {
		t.Fatalf("whoami did not report the verified tenant: %s", got)
	}
	if strings.Contains(got, "credential-bytes-never-print") {
		t.Fatal("whoami leaked resolved credential bytes")
	}

	t.Setenv("PRINTING_PRESS_CLIENT_PROFILE", "tenant-a")
	if err := BindMCPServerProfile(); err != nil {
		t.Fatal(err)
	}
	mcpRoot := RootCmd()
	if flag := mcpRoot.PersistentFlags().Lookup("client-profile"); flag == nil || !flag.Hidden {
		t.Fatal("MCP-bound root exposed the client-profile switch")
	}
	mcpRoot.SetArgs([]string{"whoami", "--client-profile", "other", "--json"})
	if err := mcpRoot.Execute(); err == nil || !strings.Contains(err.Error(), "may not switch") {
		t.Fatalf("MCP profile switch error = %v", err)
	}
}

func TestRunProfilesRejectCredentialLikeFields(t *testing.T) {
	for _, name := range []string{"api-token", "client_secret", "password", "authorization", "session-cookie"} {
		if !credentialLikeRunProfileFlag(name) {
			t.Fatalf("credential-like run-profile flag %q was accepted", name)
		}
	}
	for _, name := range []string{"region", "limit", "start-date", "compact"} {
		if credentialLikeRunProfileFlag(name) {
			t.Fatalf("safe run-profile flag %q was rejected", name)
		}
	}
}

