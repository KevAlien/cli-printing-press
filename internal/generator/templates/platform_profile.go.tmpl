	if _, err := tmp.Write(data); err != nil {
		_ = tmp.Close()
		return err
	}
	if err := tmp.Sync(); err != nil {
		_ = tmp.Close()
		return err
	}
	if err := tmp.Close(); err != nil {
		return err
	}
	return os.Rename(tmpName, path)
}

// SelectProfile applies explicit flag, environment, then global-default precedence.
func SelectProfile(explicit string) (string, error) {
	for _, candidate := range []string{explicit, os.Getenv("PRINTING_PRESS_CLIENT_PROFILE")} {
		candidate = strings.TrimSpace(candidate)
		if candidate == "" {
			continue
		}
		if err := ValidateProfileName(candidate); err != nil {
			return "", err
		}
		return candidate, nil
	}
	root, err := configRoot()
	if err != nil {
		return "", err
	}
	data, err := os.ReadFile(filepath.Join(root, "config.toml")) // #nosec G304 -- platform-owned config path.
	if errors.Is(err, os.ErrNotExist) {
		return "", errors.New("missing client profile: pass --client-profile, set PRINTING_PRESS_CLIENT_PROFILE, or configure default_client_profile")
	}
	if err != nil {
		return "", err
	}
	var cfg struct {
		DefaultClientProfile string `toml:"default_client_profile"`
	}
	if err := toml.Unmarshal(data, &cfg); err != nil {
		return "", fmt.Errorf("decode printing-press config: %w", err)
	}
	candidate := strings.TrimSpace(cfg.DefaultClientProfile)
	if candidate == "" {
		return "", errors.New("missing client profile: default_client_profile is empty")
	}
	if err := ValidateProfileName(candidate); err != nil {
		return "", err
	}
	return candidate, nil
}

func PathsFor(profileName, cliName, source string) (Paths, error) {
	if err := ValidateProfileName(profileName); err != nil {
		return Paths{}, err
	}
	cliName = normalizeSourceSlug(strings.TrimSuffix(cliName, "-pp-cli"))
	source = normalizeSourceSlug(source)
	if err := ValidateProfileName(cliName); err != nil {
		return Paths{}, fmt.Errorf("invalid CLI name: %w", err)
	}
	if err := ValidateProfileName(source); err != nil {
		return Paths{}, fmt.Errorf("invalid source name: %w", err)
	}
	configBase, err := configRoot()
	if err != nil {
		return Paths{}, err
	}
	dataBase, err := dataRoot()
	if err != nil {
		return Paths{}, err
	}
	cacheBase, err := cacheRoot()
	if err != nil {
		return Paths{}, err
	}
	stateBase, err := stateRoot()
	if err != nil {
		return Paths{}, err
	}
	configDir := filepath.Join(configBase, "clients", profileName, cliName)
	dataDir := filepath.Join(dataBase, "clients", profileName, cliName)
	cacheDir := filepath.Join(cacheBase, "clients", profileName, cliName, "responses")
	stateDir := filepath.Join(stateBase, "clients", profileName, cliName)
	profileFile, err := ProfilePath(profileName)
	if err != nil {
		return Paths{}, err
	}
	return Paths{
		ProfileFile: profileFile,
		ConfigFile:  filepath.Join(configDir, "config.toml"),
		DataFile:    filepath.Join(dataDir, "data.db"),
		CacheDir:    cacheDir,
		StateDir:    stateDir,
		ReceiptsDir: filepath.Join(stateDir, "receipts"),
	}, nil
}

func configRoot() (string, error) {
	return kindRoot("XDG_CONFIG_HOME", os.UserConfigDir, filepath.Join(".config"))
}

func dataRoot() (string, error) {
	return kindRoot("XDG_DATA_HOME", nil, filepath.Join(".local", "share"))
}

func cacheRoot() (string, error) {
	return kindRoot("XDG_CACHE_HOME", os.UserCacheDir, ".cache")
}

func stateRoot() (string, error) {
	return kindRoot("XDG_STATE_HOME", nil, filepath.Join(".local", "state"))
}

func kindRoot(envName string, platformDefault func() (string, error), homeFallback string) (string, error) {
	if value := strings.TrimSpace(os.Getenv(envName)); value != "" {
		if !filepath.IsAbs(value) {
			return "", fmt.Errorf("%s must be an absolute path", envName)
		}
		return filepath.Join(filepath.Clean(value), "printing-press"), nil
	}
	if platformDefault != nil {
		if value, err := platformDefault(); err == nil && value != "" && filepath.IsAbs(value) {
			return filepath.Join(filepath.Clean(value), "printing-press"), nil
		}
	}
	userHome, err := os.UserHomeDir()
	if err != nil {
		return "", err
	}
	return filepath.Join(userHome, homeFallback, "printing-press"), nil
}

func resolveCredentials(ctx context.Context, resolver CredentialResolver, source SourceProfile) (ResolvedCredentials, error) {
	if resolver == nil {
		return nil, errors.New("credential resolver is required")
	}
	refs := source.References()
	keys := make([]string, 0, len(refs))
	for key := range refs {
		keys = append(keys, key)
	}
	sort.Strings(keys)
	resolved := make(ResolvedCredentials, len(keys))
	for _, key := range keys {
		value, err := resolver.Resolve(ctx, refs[key])
		if err != nil {
			resolved.Zero()
			return nil, fmt.Errorf("resolve %s reference: %w", key, err)
		}
		resolved[key] = value
	}
	return resolved, nil
}

func credentialFingerprint(credentials ResolvedCredentials) (string, error) {
	key, err := loadOrCreateFingerprintKey()
	if err != nil {
		return "", err
	}
	mac := hmac.New(sha256.New, key)
	keys := make([]string, 0, len(credentials))
	for name := range credentials {
		keys = append(keys, name)
	}
	sort.Strings(keys)
	for _, name := range keys {
		_, _ = io.WriteString(mac, fmt.Sprintf("%d:%s:%d:", len(name), name, len(credentials[name])))
		_, _ = mac.Write(credentials[name])
	}
	return hex.EncodeToString(mac.Sum(nil)), nil
}

func loadOrCreateFingerprintKey() ([]byte, error) {
	root, err := stateRoot()
	if err != nil {
		return nil, err
	}
	if err := os.MkdirAll(root, 0o700); err != nil {
		return nil, err
	}
	path := filepath.Join(root, "cache-key")
	if data, err := readFingerprintKey(path); err == nil {
		return data, nil
	} else if !errors.Is(err, os.ErrNotExist) {
		return nil, err
	}
	key := make([]byte, 32)
	if _, err := rand.Read(key); err != nil {
		return nil, err
	}
	file, err := os.OpenFile(path, os.O_WRONLY|os.O_CREATE|os.O_EXCL, 0o600)
	if errors.Is(err, os.ErrExist) {
		return readFingerprintKey(path)
	}
	if err != nil {
		return nil, err
	}
	if _, err := file.Write(key); err != nil {
		_ = file.Close()
		_ = os.Remove(path)
		return nil, err
	}
	if err := file.Close(); err != nil {
		_ = os.Remove(path)
		return nil, err
	}
	return key, nil
}

func readFingerprintKey(path string) ([]byte, error) {
	info, err := os.Lstat(path)
	if err != nil {
		return nil, err
	}
	if info.Mode()&os.ModeSymlink != 0 {
		return nil, errors.New("cache fingerprint key may not be a symlink")
	}
	if info.Mode().Perm() != 0o600 {
		return nil, fmt.Errorf("cache fingerprint key permissions must be 0600, got %04o", info.Mode().Perm())
	}
	data, err := os.ReadFile(filepath.Clean(path)) // #nosec G304 -- platform-owned state path.
	if err != nil {
		return nil, err
	}
	if len(data) != 32 {
		return nil, errors.New("invalid cache fingerprint key length")
	}
	return data, nil
}
