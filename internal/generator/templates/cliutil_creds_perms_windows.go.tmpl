// S1 (Windows): refuse to load a persisted token/credentials file whose owner or
// DACL is unsafe. `chmod 0600` is a no-op on NTFS, so we read the security
// descriptor, render it to SDDL, derive the current-user SID from the process
// token, and delegate to the pure evalCredsSecurity evaluator.
package cliutil

import (
	"fmt"

	"golang.org/x/sys/windows"
)

// currentUserSID returns the current process's user SID as an SDDL string.
func currentUserSID() (string, error) {
	tok, err := windows.OpenCurrentProcessToken()
	if err != nil {
		return "", err
	}
	defer tok.Close()
	u, err := tok.GetTokenUser()
	if err != nil {
		return "", err
	}
	return u.User.Sid.String(), nil
}

// VerifyCredsPerms returns a non-nil error if path's owner/DACL is unsafe for a
// secret file. The error names remediation only — NEVER the file contents (S3).
func VerifyCredsPerms(path string) error {
	sd, err := windows.GetNamedSecurityInfo(
		path,
		windows.SE_FILE_OBJECT,
		windows.DACL_SECURITY_INFORMATION|windows.OWNER_SECURITY_INFORMATION,
	)
	if err != nil {
		return fmt.Errorf("cannot read credentials/token file ACL: %w", err)
	}
	me, err := currentUserSID()
	if err != nil {
		return fmt.Errorf("cannot resolve current user SID: %w", err)
	}
	return evalCredsSecurity(sd.String(), me)
}
