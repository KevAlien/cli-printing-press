func initializePlatformReceipt(cmd *cobra.Command, flags *rootFlags) error {
	if flags == nil || flags.platformSession == nil || flags.receiptWriter != nil {
		return nil
	}
	if !flags.receiptEnabled && strings.TrimSpace(flags.receiptFile) == "" && strings.TrimSpace(flags.auditDir) == "" {
		return nil
	}
	writer, err := platform.NewReceiptWriter(flags.platformSession, platform.ReceiptOptions{
		CLI:  platform.ReceiptCLI{Name: "{{.Name}}-pp-cli", Version: version},
		Argv: append([]string(nil), os.Args...), ReceiptFile: flags.receiptFile, AuditDir: flags.auditDir,
	})
	if err != nil {
		return err
	}
	flags.receiptWriter = writer
	cmd.Root().SetOut(writer.CaptureWriter("stdout", cmd.OutOrStdout()))
	cmd.Root().SetErr(writer.CaptureWriter("stderr", cmd.ErrOrStderr()))
	return nil
}

func finalizePlatformInvocation(flags *rootFlags, retErr *error) {
	if flags == nil {
		return
	}
	defer func() {
		if flags.platformSession != nil {
			flags.platformSession.ZeroCredentials()
		}
	}()
	if flags.receiptWriter == nil {
		return
	}
	writer := flags.receiptWriter
	flags.receiptWriter = nil
	status := "success"
	exitCode := 0
	if retErr != nil && *retErr != nil {
		status = "error"
		exitCode = ExitCode(*retErr)
	}
	if err := writer.Finalize(context.Background(), status, exitCode, nil, flags.platformSession.OutputMetadata(), flags.platformSession.RateLimitMetadata()); err != nil && retErr != nil && *retErr == nil {
		*retErr = err
	}
}
