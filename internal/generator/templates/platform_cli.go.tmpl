func newPlatformClientMigrateCmd(flags *rootFlags) *cobra.Command {
	var values platformSourceFlags
	var legacyConfig, legacyDB string
	command := &cobra.Command{Use: "migrate <name>", Short: "Create or add a source only after a live gate; preserve and quarantine unproven legacy state", Args: cobra.ExactArgs(1), RunE: func(cmd *cobra.Command, args []string) (retErr error) {
		if registeredPlatformSource == nil {
			return errors.New("this CLI has no registered tenant identity adapter")
		}
		candidate := values.sourceProfile()
		profile, err := platform.LoadProfile(args[0])
		alreadyMigrated := false
		switch {
		case err == nil:
			if existing, ok := profile.Sources[registeredPlatformSource.Source]; ok {
				if !reflect.DeepEqual(existing, candidate) {
					return errors.New("existing source differs from the requested migration; refusing to overwrite trusted identity configuration")
				}
				alreadyMigrated = true
			} else {
				profile.Sources[registeredPlatformSource.Source] = candidate
			}
		case errors.Is(err, os.ErrNotExist):
			profile = &platform.Profile{SchemaVersion: platform.ProfileSchemaVersion, Name: args[0], Sources: map[string]platform.SourceProfile{registeredPlatformSource.Source: candidate}}
		default:
			return err
		}
		legacy, err := inspectLegacyMigrationState(legacyConfig, legacyDB)
		if err != nil {
			return err
		}
		session, err := platform.PrepareProfileSourceFromConfig(profile, "{{.Name}}-pp-cli", registeredPlatformSource.Source)
		if err != nil {
			return err
		}
		flags.platformSession = session
		if err := initializePlatformReceipt(cmd, flags); err != nil {
			return err
		}
		defer finalizePlatformInvocation(flags, &retErr)
		if err := platform.VerifyPreparedProfileSource(cmd.Context(), session, platformResolverFactory(), registeredPlatformSource.Adapter); err != nil {
			return err
		}
		if !alreadyMigrated {
			if err := platform.SaveProfile(profile); err != nil {
				return err
			}
		}
		return flags.printJSON(cmd, map[string]any{
			"client_profile": profile.Name, "source": registeredPlatformSource.Source,
			"gate": session.GateOutcome, "already_migrated": alreadyMigrated,
			"profile_written": !alreadyMigrated, "legacy_state": legacy,
		})
	}}
	values.addFlags(command)
	command.Flags().StringVar(&legacyConfig, "legacy-config", "", "Existing legacy config to preserve and mark as unadopted")
	command.Flags().StringVar(&legacyDB, "legacy-db", "", "Existing legacy database to preserve and quarantine")
	return command
}

func inspectLegacyMigrationState(legacyConfig, legacyDB string) (map[string]any, error) {
	legacy := map[string]any{
		"status": "none", "preserved": true,
		"reason": "legacy state has no verified tenant metadata and is never adopted automatically; perform a clean profile-scoped sync",
	}
	for kind, path := range map[string]string{"config": legacyConfig, "database": legacyDB} {
		if strings.TrimSpace(path) == "" {
			continue
		}
		info, err := os.Lstat(path)
		if err != nil {
			return nil, fmt.Errorf("inspect legacy %s: %w", kind, err)
		}
		if info.Mode()&os.ModeSymlink != 0 {
			return nil, fmt.Errorf("legacy %s may not be a symlink", kind)
		}
		legacy[kind] = map[string]any{"path": path, "status": "quarantined", "copied": false}
		legacy["status"] = "quarantined"
	}
	return legacy, nil
}

