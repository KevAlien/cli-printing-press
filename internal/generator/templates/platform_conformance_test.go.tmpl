	t.Setenv("PRINTING_PRESS_CLIENT_PROFILE", "synthetic")
	selected, err := SelectProfile("")
	if err != nil || selected != "synthetic" {
		t.Fatalf("env selection = %q, err = %v", selected, err)
	}
	selected, err = SelectProfile("explicit")
	if err != nil || selected != "explicit" {
		t.Fatalf("explicit selection = %q, err = %v", selected, err)
