func TestSharedLimiterHonorsBurstAndCrossInstanceLedger(t *testing.T) {
	setPlatformRoots(t)
	paths, err := PathsFor("synthetic", "sample-pp-cli", "sample")
	if err != nil {
		t.Fatal(err)
	}
	session := &Session{ProfileName: "synthetic", Source: "sample", CredentialFingerprint: "fingerprint", GateOutcome: GateVerified, Paths: paths}
	budget := EndpointBudget{Class: "GET /profiles", Steady: 1, Interval: time.Second, Burst: 2, MaxAttempts: 3, RetryBudget: 10 * time.Second}
	first, err := NewEndpointLimiter(session, budget)
	if err != nil {
		t.Fatal(err)
	}
	second, err := NewEndpointLimiter(session, budget)
	if err != nil {
		t.Fatal(err)
	}
	now := time.Date(2026, time.July, 20, 0, 0, 0, 0, time.UTC)
	waits := []time.Duration{}
	first.now = func() time.Time { return now }
	second.now = func() time.Time { return now }
	first.sleep = func(_ context.Context, wait time.Duration) error { waits = append(waits, wait); return nil }
	second.sleep = func(_ context.Context, wait time.Duration) error { waits = append(waits, wait); return nil }
	if err := first.Wait(context.Background()); err != nil {
		t.Fatal(err)
	}
	if err := first.Wait(context.Background()); err != nil {
		t.Fatal(err)
	}
	if len(waits) != 0 {
		t.Fatalf("burst requests waited: %v", waits)
	}
	if err := first.Wait(context.Background()); err != nil {
		t.Fatal(err)
	}
	if err := second.Wait(context.Background()); err != nil {
		t.Fatal(err)
	}
	if len(waits) != 2 || waits[0] != time.Second || waits[1] != 2*time.Second {
		t.Fatalf("shared ledger waits = %v", waits)
	}
	if info, err := os.Stat(first.path); err != nil || info.Mode().Perm() != 0o600 {
		t.Fatalf("limiter ledger mode = %v err=%v", info.Mode().Perm(), err)
	}
}

func TestReceiptConformance(t *testing.T) {
	root := setPlatformRoots(t)
	paths, err := PathsFor("synthetic", "sample-pp-cli", "sample")
	if err != nil {
		t.Fatal(err)
	}
	session := &Session{Profile: &Profile{Name: "synthetic"}, ProfileName: "synthetic", CLI: "sample", Source: "sample", GateOutcome: GateVerified, ExpectedIdentity: map[string]string{"account_id": "one"}, ObservedIdentity: map[string]string{"account_id": "one"}, Paths: paths}
	receiptPath := filepath.Join(root, "receipt.json")
	auditDir := filepath.Join(root, "audit")
	writer, err := NewReceiptWriter(session, ReceiptOptions{CLI: ReceiptCLI{Name: "sample-pp-cli", Version: "test"}, Argv: []string{"sample-pp-cli", "--client-profile", "synthetic", "list"}, ReceiptFile: receiptPath, AuditDir: auditDir})
	if err != nil {
		t.Fatal(err)
	}
	var output bytes.Buffer
	captured := writer.CaptureWriter("stdout", &output)
	if _, err := captured.Write([]byte("aggregate-only\n")); err != nil {
		t.Fatal(err)
	}
	if err := writer.Finalize(context.Background(), "success", 0, map[string]RowCounts{"orders": {Read: 2, Emitted: 2}}, OutputMetadata{}, RateLimitMetadata{Requests: 1}); err != nil {
		t.Fatal(err)
	}
	data, err := os.ReadFile(receiptPath)
	if err != nil {
		t.Fatal(err)
	}
	if strings.Contains(string(data), "synthetic-credential") || strings.Contains(string(data), "aggregate-only") {
		t.Fatal("receipt persisted secret or output payload bytes")
	}
	var receipt Receipt
	if err := json.Unmarshal(data, &receipt); err != nil {
		t.Fatal(err)
	}
	if len(receipt.Outputs) != 1 || receipt.Outputs[0].Bytes != int64(len("aggregate-only\n")) || receipt.Outputs[0].SHA256 == "" {
		t.Fatalf("receipt outputs = %+v", receipt.Outputs)
	}
	if _, err := os.Stat(filepath.Join(auditDir, "index.jsonl")); err != nil {
		t.Fatal(err)
	}
}
