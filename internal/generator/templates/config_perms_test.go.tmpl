// TestLoad_RefusesSymlinkToLoosePermsTarget locks the canonicalize-first
// property: a config symlinked to a loose-perms target must be refused.
func TestLoad_RefusesSymlinkToLoosePermsTarget(t *testing.T) {
	if runtime.GOOS == "windows" {
		t.Skip("POSIX symlink-perms test; Windows perms enforced via DACL")
	}
	clearCredEnv(t)
	dir := t.TempDir()
	target := filepath.Join(dir, "target."+strings.TrimPrefix(filepath.Ext(configFileName()), "."))
	writeTokenConfig(t, target)
	if err := os.Chmod(target, 0o644); err != nil {
		t.Fatal(err)
	}
	link := filepath.Join(dir, configFileName())
	if err := os.Symlink(target, link); err != nil {
		t.Fatal(err)
	}
	cfg, err := Load(link)
	if err != nil {
		t.Fatalf("symlink-to-loose-target must be a silent miss, got error: %v", err)
	}
	if cfg.hasCredentialFields() {
		t.Error("symlink to loose-perms target must be refused (canonicalize-first)")
	}
	if cfg.RefreshToken != "" {
		t.Errorf("symlink to loose-perms target must be refused; got %q", cfg.RefreshToken)
	}
}

