// TestLoad_ReseedsFromEnvAfterOverPermissiveRefusal proves fail-toward-re-mint:
// after refusing the exposed on-disk token, the env credential re-seeds, so the
// operator is left with a working tool, never using the exposed on-disk token.
func TestLoad_ReseedsFromEnvAfterOverPermissiveRefusal(t *testing.T) {
	const envValue = "PAT-FROM-ENV-BOOTSTRAP"
	t.Setenv("{{if .Auth.EnvVarSpecs}}{{(index .Auth.EnvVarSpecs 0).Name}}{{else}}{{index .Auth.EnvVars 0}}{{end}}", envValue)
	dir := t.TempDir()
	p := filepath.Join(dir, configFileName())
	writeTokenConfig(t, p)
	grantBroad(t, p)

	cfg, err := Load(p)
	if err != nil {
		t.Fatalf("Load error: %v", err)
	}
	// The exposed on-disk token (written to refresh_token) must never survive.
	if cfg.RefreshToken == sampleReadPermsSecret {
		t.Fatal("exposed on-disk token must never win after an over-permissive refusal")
	}
	// The env credential re-seeded, and it is the source (field-agnostic).
	if !cfg.hasCredentialFields() {
		t.Error("expected env re-seed to populate a credential after refusal")
	}
	if !strings.HasPrefix(cfg.AuthSource, "env:") {
		t.Errorf("expected env-sourced credential after refusal, got AuthSource %q", cfg.AuthSource)
	}
}
