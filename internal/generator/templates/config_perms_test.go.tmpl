// TestLoad_RefusesOverPermissiveConfigOnRead: an owner-locked token config is a
// hit; broadening it to group/world-readable makes Load refuse it on read (a
// silent miss), not trust it and not error.
func TestLoad_RefusesOverPermissiveConfigOnRead(t *testing.T) {
	clearCredEnv(t)
	dir := t.TempDir()
	p := filepath.Join(dir, configFileName())
	writeTokenConfig(t, p)
	lockOwnerOnly(t, p)

	// Owner-locked → honored (a hit): the field-agnostic observable reports a
	// credential, and the value landed in the refresh_token slot we wrote.
	cfg, err := Load(p)
	if err != nil {
		t.Fatalf("Load returned error on owner-locked config: %v", err)
	}
	if !cfg.hasCredentialFields() {
		t.Fatal("precondition: owner-locked config should load a credential")
	}
	if cfg.RefreshToken != sampleReadPermsSecret {
		t.Fatalf("precondition: owner-locked config should load the token, got %q", cfg.RefreshToken)
	}

	// Broaden perms → the config holding a live token MUST be refused on read
	// (a silent miss), not trusted and not an error.
	grantBroad(t, p)
	cfg, err = Load(p)
	if err != nil {
		t.Fatalf("over-permissive config must be a silent miss, got error: %v", err)
	}
	if cfg == nil {
		t.Fatal("Load returned nil *Config on over-permissive config")
	}
	if cfg.hasCredentialFields() {
		t.Errorf("over-permissive config must be a miss; a credential leaked into cfg")
	}
	if cfg.RefreshToken != "" {
		t.Errorf("over-permissive config must be a miss; token leaked into cfg: %q", cfg.RefreshToken)
	}
	if cfg.AuthSource != "" {
		t.Errorf("over-permissive config must be a miss; AuthSource should be unset, got %q", cfg.AuthSource)
	}
	if cfg.BaseURL != "https://example.test/v1" {
		t.Errorf("over-permissive config must preserve non-secret settings; BaseURL = %q", cfg.BaseURL)
	}
}

