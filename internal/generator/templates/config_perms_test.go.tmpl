// Read-time permission enforcement for the persisted token config. This config
// can hold a live bearer / OAuth token, so Load must refuse a group/world-
// readable file on READ (a silent miss → env re-seed → the next save() rewrites
// 0600), not only enforce 0600 on write. The assertions are field-agnostic: the
// on-disk secret is written to the always-present builtin `refresh_token` slot,
// and the observable is Config.hasCredentialFields() — the same predicate Load
// itself uses to decide AuthSource — so this test holds regardless of which
// credential field a given spec actually persists. Cross-platform: POSIX chmod +
// Windows icacls, skip-guarded; symlink cases are POSIX-only.
package config

import (
	"os"
	"os/exec"
	"path/filepath"
	"runtime"
	"strings"
	"testing"
)

// sampleReadPermsSecret is an exposed on-disk token value. It is written into
// the builtin refresh_token slot (present in every token-bearing config) so the
// refusal assertions never depend on a spec-specific field name.
const sampleReadPermsSecret = "RT-LIVE-90DAY-SECRET-DO-NOT-LEAK"

// clearCredEnv unsets every credential env var Load reads AFTER the file, so
// the silent-miss / hit assertions are deterministic regardless of the
// developer's or CI's ambient environment (an ambient PAT would otherwise
// re-seed a "miss" and make hasCredentialFields() true).
func clearCredEnv(t *testing.T) {
	t.Helper()
{{- if .Auth.EnvVarSpecs}}
{{- range .Auth.EnvVarSpecs}}
	t.Setenv("{{.Name}}", "")
{{- end}}
{{- else if .Auth.EnvVars}}
{{- range .Auth.EnvVars}}
	t.Setenv("{{.}}", "")
{{- end}}
{{- end}}
{{- range .Auth.AdditionalHeaders}}
	t.Setenv("{{.EnvVar.Name}}", "")
{{- end}}
}

func runPermsCmd(t *testing.T, name string, args ...string) error {
	t.Helper()
	out, err := exec.Command(name, args...).CombinedOutput()
	if err != nil {
		t.Logf("%s %v: %v\n%s", name, args, err, out)
	}
	return err
}

// lockOwnerOnly restricts p to owner-only access (POSIX 0600 / Windows DACL to
// the current user). icacls failures skip the test rather than fail it.
func lockOwnerOnly(t *testing.T, p string) {
	t.Helper()
	if runtime.GOOS == "windows" {
		u := os.Getenv("USERNAME")
		if err := runPermsCmd(t, "icacls", p, "/inheritance:r", "/grant:r", u+":F"); err != nil {
			t.Skipf("icacls lock failed (environment); skipping perm-sensitive test: %v", err)
		}
	} else {
		if err := os.Chmod(p, 0o600); err != nil {
			t.Fatal(err)
		}
	}
}

// grantBroad makes p group/world-accessible (POSIX 0644 / Windows adds a broad
// BUILTIN\Users allow-ACE by SID, locale-independent). icacls failures skip.
func grantBroad(t *testing.T, p string) {
	t.Helper()
	if runtime.GOOS == "windows" {
		if err := runPermsCmd(t, "icacls", p, "/grant", "*S-1-5-32-545:R"); err != nil {
			t.Skipf("icacls grant failed; skipping: %v", err)
		}
	} else {
		if err := os.Chmod(p, 0o644); err != nil {
			t.Fatal(err)
		}
	}
}

// writeTokenConfig writes a config file holding a live token in the builtin
// refresh_token slot at 0600, in this bundle's serialization format.
func writeTokenConfig(t *testing.T, p string) {
	t.Helper()
{{- if eq .Config.Format "toml"}}
	content := "base_url = \"https://example.test/v1\"\n" +
		"refresh_token = \"" + sampleReadPermsSecret + "\"\n"
{{- else}}
	content := "{\n" +
		"  \"base_url\": \"https://example.test/v1\",\n" +
		"  \"refresh_token\": \"" + sampleReadPermsSecret + "\"\n" +
		"}\n"
{{- end}}
	if err := os.WriteFile(p, []byte(content), 0o600); err != nil {
		t.Fatal(err)
	}
}

// writeCorruptTokenConfig writes a file that carries the token value but fails
// to parse, so a test can assert the parse-error path (S3) never echoes it.
func writeCorruptTokenConfig(t *testing.T, p string) {
	t.Helper()
{{- if eq .Config.Format "toml"}}
	// Unterminated basic string: go-toml/v2 reports "basic strings cannot have
	// new lines" — a structural message that never quotes the value.
	content := "base_url = \"https://example.test/v1\"\n" +
		"refresh_token = \"" + sampleReadPermsSecret + "\n"
{{- else}}
	// Truncated object: encoding/json reports "unexpected end of JSON input" —
	// a structural message that never contains the token value.
	content := "{\n" +
		"  \"refresh_token\": \"" + sampleReadPermsSecret + "\"\n"
{{- end}}
	if err := os.WriteFile(p, []byte(content), 0o600); err != nil {
		t.Fatal(err)
	}
}

